exports[`MCP-lite showroom → R3F export validation > 05 full workflow — module: semantic components + handler scaffolding > 05-workflow-module 1`] = `
"/* eslint-disable */
/* Auto-generated by Diorama R3F bridge. Review TODOs before shipping. */
import { useState } from 'react';
import type { ReactNode } from 'react';
import type { ThreeElements } from '@react-three/fiber';

type SemanticNodeProps = Omit<ThreeElements['group'], 'children'> & {
  sourceId: string;
  semanticRole: string;
  renderMesh?: boolean;
  children?: ReactNode;
  onSelect?: () => void;
  onHoverStart?: () => void;
  onHoverEnd?: () => void;
};

function SemanticNode(props: SemanticNodeProps) {
  const { sourceId, semanticRole, renderMesh, children, onSelect, onHoverStart, onHoverEnd, ...groupProps } = props;
  return (
    <group
      {...groupProps}
      userData={{ sourceId, semanticRole }}
      onPointerOver={onHoverStart}
      onPointerOut={onHoverEnd}
      onClick={onSelect}
    >
      {renderMesh ? (
        <mesh castShadow receiveShadow>
          <boxGeometry args={[1, 1, 1]} />
          <meshStandardMaterial color="#9ca3af" />
        </mesh>
      ) : null}
      {children}
    </group>
  );
}

type SemanticComponentProps = Omit<SemanticNodeProps, 'semanticRole'>;

function DisplaySurface(props: SemanticComponentProps) {
  return <SemanticNode {...props} semanticRole="display" />;
}

function EnvironmentGroup(props: SemanticComponentProps) {
  return <SemanticNode {...props} semanticRole="environment" />;
}

function Product(props: SemanticComponentProps) {
  return <SemanticNode {...props} semanticRole="product" />;
}

function SceneLight(props: ThreeElements['group'] & { sourceId: string; lightKind: 'ambient' | 'directional'; lightIntensity?: number; lightCastShadow?: boolean; children?: ReactNode }) {
  const { sourceId, lightKind, lightIntensity, lightCastShadow, children, ...groupProps } = props;
  return (
    <group {...groupProps} userData={{ sourceId, semanticRole: 'light' }}>
      {lightKind === 'ambient' ? (
        <ambientLight intensity={lightIntensity} />
      ) : (
        <directionalLight intensity={lightIntensity} castShadow={lightCastShadow} />
      )}
      {children}
    </group>
  );
}

function SeatingElement(props: SemanticComponentProps) {
  return <SemanticNode {...props} semanticRole="seating" />;
}

export function McpLiteShowroom() {
  const [selectedId, setSelectedId] = useState<string | null>(null);

  const handleSelect = (id: string) => {
    setSelectedId(id);
  };

  const handleHoverStart = (id: string) => {
    // TODO: highlight object with this source id.
    void id;
  };

  const handleHoverEnd = (id: string) => {
    // TODO: clear highlight for this source id.
    void id;
  };

  const handleFocusCamera = (id: string) => {
    // TODO: move or retarget the app camera for this source id.
    void id;
  };

  return (
    <>
      {/* Semantic group: display_area | role=display | nodes=product_01,product_02,product_03,display_table,display_plinth */}
      {/* Semantic group: environment | role=environment | nodes=floor,wall,backdrop_panel */}
      {/* Semantic group: lighting_zone | role=lighting | nodes=light_key,light_fill */}
      {/* Semantic group: seating_area | role=seating | nodes=bench,chair */}
      {/* showroom-root - Messy Product Showroom */}
      <group name="Messy Product Showroom" position={[0, 0, 0]} rotation={[0, 0, 0]} scale={[1, 1, 1]}>
        {/* floor - Floor | role=environment | group=environment */}
        <EnvironmentGroup
          sourceId="floor"
          name="Floor"
          position={[0, -0.05, 0]}
          rotation={[0, 0, 0]}
          scale={[8, 0.1, 6]}
          renderMesh
        />
        {/* wall - North Wall | role=environment | group=environment */}
        <EnvironmentGroup
          sourceId="wall"
          name="North Wall"
          position={[0, 1.6, -3]}
          rotation={[0, 0, 0]}
          scale={[8, 3.2, 0.12]}
          renderMesh
        />
        {/* product_01 - Product 01 | role=product | group=display_area | traits=clickable,hoverable,displayable,focusable | behavior=click_select,hover_highlight,show_info,focus_camera */}
        <Product
          sourceId="product_01"
          name="Product 01"
          position={[-1.25, 0.5, 0]}
          rotation={[0, 0.4, 0]}
          scale={[0.65, 0.9, 0.65]}
          renderMesh
          onHoverStart={() => handleHoverStart('product_01')}
          onHoverEnd={() => handleHoverEnd('product_01')}
          onSelect={() => {
            handleSelect('product_01');
            handleFocusCamera('product_01');
          }}
        />
        {selectedId === 'product_01' ? (
          <>{/* TODO: render info panel for Product information: Interactive showroom item generated from structured scene metadata.. */}</>
        ) : null}
        {/* bench - Bench | role=seating | group=seating_area | traits=seatable,focusable | behavior=focus_camera,anchor_point */}
        {/* TODO: anchor_point is scaffolded as a developer hook; no runtime behavior is generated. */}
        <SeatingElement
          sourceId="bench"
          name="Bench"
          position={[-2.6, 0.32, 1.9]}
          rotation={[0, 0.18, 0]}
          scale={[1.5, 0.45, 0.55]}
          renderMesh
          onSelect={() => handleFocusCamera('bench')}
        />
        {/* display_table - Display Table | role=display | group=display_area | traits=displayable | behavior=show_info */}
        <DisplaySurface
          sourceId="display_table"
          name="Display Table"
          position={[-0.4, 0.28, 0.15]}
