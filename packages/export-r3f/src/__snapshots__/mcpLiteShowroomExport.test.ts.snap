        <Product
          sourceId="product_02"
          name="Product 02"
          position={[0, 0.5, 0]}
          rotation={[0, -0.25, 0]}
          scale={[0.8, 0.7, 0.8]}
          renderMesh
          onHoverStart={() => handleHoverStart('product_02')}
