        <mesh castShadow receiveShadow>
          <boxGeometry args={[1, 1, 1]} />
          <meshStandardMaterial color="#9ca3af" />
        </mesh>
      </group>
      {/* display_plinth - Display Plinth */}
      <group name="Display Plinth" position={[1.3, 0.32, 1.15]} rotation={[0, 0.1, 0]} scale={[0.9, 0.65, 0.9]}>
        <mesh castShadow receiveShadow>
          <boxGeometry args={[1, 1, 1]} />
          <meshStandardMaterial color="#9ca3af" />
        </mesh>
      </group>
      {/* product_02 - Product 02 */}
      <group name="Product 02" position={[2.1, 0.55, -0.2]} rotation={[0, -0.25, 0]} scale={[0.8, 0.7, 0.8]}>
        <mesh castShadow receiveShadow>
          <boxGeometry args={[1, 1, 1]} />
          <meshStandardMaterial color="#9ca3af" />
        </mesh>
      </group>
      {/* light_key - Light Key */}
      <group name="Light Key" position={[-3.2, 3.4, 2.2]} rotation={[0, 0.5, 0]} scale={[0.25, 0.25, 0.25]}>
        <directionalLight intensity={1.2} castShadow />
      </group>
