        <mesh castShadow receiveShadow>
          <boxGeometry args={[1, 1, 1]} />
          <meshStandardMaterial color="#9ca3af" />
        </mesh>
      </group>
      {/* product_03 - Product 03 */}
      <group name="Product 03" position={[0.35, 0.8, 1.45]} rotation={[0, 0.85, 0]} scale={[0.55, 1.1, 0.55]}>
        <mesh castShadow receiveShadow>
          <boxGeometry args={[1, 1, 1]} />
          <meshStandardMaterial color="#9ca3af" />
        </mesh>
      </group>
      {/* light_fill - Light Fill */}
      <group name="Light Fill" position={[3.1, 2.4, 2.5]} rotation={[0, -0.4, 0]} scale={[0.25, 0.25, 0.25]}>
        <ambientLight intensity={0.35} />
      </group>
      {/* chair - Chair */}
