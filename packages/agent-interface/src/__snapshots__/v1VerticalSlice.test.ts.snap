// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`V1 vertical slice workflow > runs generate -> ingest -> structure -> interactive -> arrange -> export 1`] = `
"/* eslint-disable */
/* Auto-generated by Diorama R3F bridge. Review TODOs before shipping. */
import { useState } from 'react';
import type { ReactNode } from 'react';
import type { ThreeElements } from '@react-three/fiber';
import { useGLTF } from '@react-three/drei';

function AssetModel({ uri }: { uri: string }) {
  const gltf = useGLTF(uri);
  return <primitive object={gltf.scene.clone()} />;
}

type SemanticNodeProps = Omit<ThreeElements['group'], 'children'> & {
  sourceId: string;
  semanticRole: string;
  renderMesh?: boolean;
  assetUri?: string;
  children?: ReactNode;
  onSelect?: () => void;
  onHoverStart?: () => void;
  onHoverEnd?: () => void;
};

function SemanticNode(props: SemanticNodeProps) {
  const { sourceId, semanticRole, renderMesh, assetUri, children, onSelect, onHoverStart, onHoverEnd, ...groupProps } = props;
  return (
    <group
      {...groupProps}
      userData={{ sourceId, semanticRole }}
      onPointerOver={onHoverStart}
      onPointerOut={onHoverEnd}
      onClick={onSelect}
    >
      {assetUri ? (
        <AssetModel uri={assetUri} />
      ) : renderMesh ? (
        <mesh castShadow receiveShadow>
          <boxGeometry args={[1, 1, 1]} />
          <meshStandardMaterial color="#9ca3af" />
        </mesh>
      ) : null}
      {children}
    </group>
  );
}

type SemanticComponentProps = Omit<SemanticNodeProps, 'semanticRole'>;

function Product(props: SemanticComponentProps) {
  return <SemanticNode {...props} semanticRole="product" />;
}

function DisplayArea({ children }: { children: ReactNode }) {
  return <group name="DisplayArea">{children}</group>;
}

export function GeneratedChairScene() {
  const [selectedId, setSelectedId] = useState<string | null>(null);

  const handleSelect = (id: string) => {
    setSelectedId(id);
  };

  const handleHoverStart = (id: string) => {
    // TODO: highlight object with this source id.
    void id;
  };

  const handleHoverEnd = (id: string) => {
    // TODO: clear highlight for this source id.
    void id;
  };

  const handleFocusCamera = (id: string) => {
    // TODO: move or retarget the app camera for this source id.
    void id;
  };

  return (
    <>
      {/* Semantic group: display_area | role=display | nodes=asset-1tcs5oq-node */}
      {/* <scene-id> - Root */}
      <group name="Root" position={[0, 0, 0]} rotation={[0, 0, 0]} scale={[1, 1, 1]}>
        {/* Semantic group: display_area | role=display | nodes=asset-1tcs5oq-node */}
        <DisplayArea>
          {/* asset-1tcs5oq-node - Generated Product | role=product | group=display_area | traits=clickable,hoverable,displayable,focusable | asset=uri | behavior=click_select,hover_highlight,show_info,focus_camera */}
          <Product
            sourceId="asset-1tcs5oq-node"
            name="Generated Product"
            position={[0, 0.5, 0]}
            rotation={[0, 0, 0]}
            scale={[1, 1, 1]}
            assetUri="/assets/generated/meshy-1tcs5oq.glb"
            onHoverStart={() => handleHoverStart('asset-1tcs5oq-node')}
            onHoverEnd={() => handleHoverEnd('asset-1tcs5oq-node')}
            onSelect={() => {
              handleSelect('asset-1tcs5oq-node');
              handleFocusCamera('asset-1tcs5oq-node');
            }}
          />
          {selectedId === 'asset-1tcs5oq-node' ? (
            <>{/* TODO: render info panel for Product information: Interactive showroom item generated from structured scene metadata.. */}</>
          ) : null}
        </DisplayArea>
      </group>
    </>
  );
}
"
